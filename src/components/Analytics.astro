<script is:inline>
  function loadAnalytics() {
    var gaScript = document.createElement('script');
    gaScript.async = true;
    gaScript.src = 'https://www.googletagmanager.com/gtag/js?id=G-FHHSX9LYS3';
    document.head.appendChild(gaScript);

    ['/js/google_analytics.js', '/js/additional_gtag_analytics.js', '/js/ms_clarity_analytics.js'].forEach(function(src) {
      var s = document.createElement('script');
      s.src = src;
      document.head.appendChild(s);
    });

    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          window.dataLayer = window.dataLayer || [];
          window.dataLayer.push({ event: 'content_read', url: window.location.pathname });
          observer.disconnect();
        }
      });
    });

    document.querySelectorAll('.content-read-marker').forEach(function(el) {
      observer.observe(el);
    });
  }

  if ('requestIdleCallback' in window) {
    requestIdleCallback(loadAnalytics);
  } else {
    setTimeout(loadAnalytics, 200);
  }
</script>
